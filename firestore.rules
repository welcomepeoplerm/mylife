rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funzione helper per verificare se l'utente è admin
    function isAdmin() {
      return request.auth != null;
    }
    
    // Regole per le collezioni principali (home, journey, taste, events)
    // Lettura pubblica, scrittura per utenti autenticati
    match /{collection}/{document=**} {
      allow read: if collection in ['home', 'journey', 'taste', 'events'];
      allow write: if request.auth != null && collection in ['home', 'journey', 'taste', 'events'];
    }
    
    // Regole per la collezione settings (configurazione UI)
    // Lettura pubblica, scrittura solo per admin
    match /settings/{document} {
      allow read: if true;  // Tutti possono leggere le impostazioni UI
      allow write: if isAdmin();  // Solo gli admin possono modificare
    }
    
    // Regole per la collezione admins (gestione utenti admin)
    match /admins/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Regole per FCM Tokens - dispositivi registrati per notifiche push
    match /fcmTokens/{tokenId} {
      allow read: if isAdmin();  // Solo admin possono leggere i token
      allow write: if true;  // L'app può registrare token senza autenticazione
    }
    
    // Regole per Notifications - storico notifiche inviate
    match /notifications/{notificationId} {
      allow read, write: if isAdmin();  // Solo admin possono gestire notifiche
    }
    
    // Negare accesso a tutte le altre collezioni
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
