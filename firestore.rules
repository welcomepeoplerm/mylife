rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funzione helper per verificare se l'utente è admin
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email.matches('.*@admin\\..*') ||
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Regole per le collezioni principali (home, journey, taste)
    // Lettura pubblica, scrittura solo per admin
    match /{collection}/{document=**} {
      allow read: if collection in ['home', 'journey', 'taste'];
      allow write: if isAdmin() && collection in ['home', 'journey', 'taste'];
    }
    
    // Regole per la collezione settings (configurazione UI)
    // Lettura pubblica, scrittura solo per admin
    match /settings/{document} {
      allow read: if true;  // Tutti possono leggere le impostazioni UI
      allow write: if isAdmin();  // Solo gli admin possono modificare
    }
    
    // Regole per la collezione admins (gestione utenti admin)
    match /admins/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Negare accesso a tutte le altre collezioni
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
